# Telegram userbot — logs in as YOU (required)
# Get these from https://my.telegram.org → "API development tools"
TG_USER_BOT_API_ID=
TG_USER_BOT_API_HASH=

# Telegram control bot (required)
# Create the bot via @BotFather, then ask @userinfobot for TG_OWNER_USER_ID
TG_CONTROL_BOT_TOKEN=
TG_OWNER_USER_ID=
# Optional: the bot's @handle (without the @), for display in /start. Not required.
TG_CONTROL_BOT_NAME=

# Signal (optional during local Telegram-only testing — leave SIGNAL_PHONE_NUMBER blank
# to skip the Signal listener entirely)
SIGNAL_API_URL=http://signal-api:8080
SIGNAL_PHONE_NUMBER=

# General
TIMEZONE=Europe/Berlin
LOG_LEVEL=INFO

# Host user UID/GID for signal-cli-rest-api bind-mount ownership.
# Leave blank — install.sh fills these from `id -u` / `id -g` on first run
# so signal-cli inside the container can write to ./environment/signal-data.
# On a Synology / QNAP NAS your user is typically UID 1026+, not 1000.
# Override manually only if you want the data owned by a different account.
SIGNAL_CLI_UID=
SIGNAL_CLI_GID=
