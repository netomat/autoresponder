# Telegram (required)
# Get these from https://my.telegram.org → "API development tools"
TG_API_ID=
TG_API_HASH=

# Telegram control bot (required)
# Create the bot via @BotFather, then ask @userinfobot for OWNER_USER_ID
CONTROL_BOT_TOKEN=
OWNER_USER_ID=

# Signal (optional during local Telegram-only testing — leave SIGNAL_PHONE_NUMBER blank
# to skip the Signal listener entirely)
SIGNAL_API_URL=http://signal-api:8080
SIGNAL_PHONE_NUMBER=

# General
TIMEZONE=Europe/Berlin
LOG_LEVEL=INFO
